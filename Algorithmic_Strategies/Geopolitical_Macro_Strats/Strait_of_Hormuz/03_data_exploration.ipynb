   "source": [
    "# Data Exploration Notebook\n",
    "Comprehensive exploration of all asset classes in the Data folder"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette('husl')\n",
    "%matplotlib inline\n",
    "\n",
    "plt.rcParams['figure.figsize'] = (16, 8)\n",
    "plt.rcParams['font.size'] = 11"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Commodities Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "commodities_path = Path('Data/Commodities')\n",
    "commodity_tickers = ['BDRY', 'BNO', 'UNG', 'USO']\n",
    "\n",
    "commodities_data = {}\n",
    "for ticker in commodity_tickers:\n",
    "    df = pd.read_parquet(commodities_path / f'{ticker}.parquet')\n",
    "    commodities_data[ticker] = df\n",
    "\n",
    "commodities_data['BDRY'].head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "commodities_data['BDRY'].info()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "commodities_data['BDRY'].describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 2, figsize=(18, 10))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for idx, ticker in enumerate(commodity_tickers):\n",
    "    df = commodities_data[ticker]\n",
    "    axes[idx].plot(df.index, df['Close'], linewidth=2)\n",
    "    axes[idx].set_title(f'{ticker} Price History', fontsize=14, fontweight='bold')\n",
    "    axes[idx].set_xlabel('Date')\n",
    "    axes[idx].set_ylabel('Price')\n",
    "    axes[idx].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Forex Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "forex_path = Path('Data/Forex')\n",
    "forex_pairs = [\n",
    "    'AUD_USD_LNG_Exporter',\n",
    "    'USD_CAD_Oil_Exporter',\n",
    "    'USD_CNH_Strategic_Importer',\n",
    "    'USD_INR_Oil_Importer',\n",
    "    'USD_JPY_Oil_Importer',\n",
    "    'USD_KRW_Oil_Importer',\n",
    "    'USD_NOK_Gas_Exporter'\n",
    "]\n",
    "\n",
    "forex_data = {}\n",
    "for pair in forex_pairs:\n",
    "    df = pd.read_parquet(forex_path / f'{pair}.parquet')\n",
    "    forex_data[pair] = df\n",
    "\n",
    "forex_data['USD_JPY_Oil_Importer'].head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "forex_data['USD_JPY_Oil_Importer'].describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(4, 2, figsize=(18, 16))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for idx, pair in enumerate(forex_pairs):\n",
    "    df = forex_data[pair]\n",
    "    col_name = df.columns[0]\n",
    "    axes[idx].plot(df.index, df[col_name], linewidth=2)\n",
    "    axes[idx].set_title(f'{pair.replace(\"_\", \" \")}', fontsize=12, fontweight='bold')\n",
    "    axes[idx].set_xlabel('Date')\n",
    "    axes[idx].set_ylabel('Exchange Rate')\n",
    "    axes[idx].grid(True, alpha=0.3)\n",
    "\n",
    "axes[-1].axis('off')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
