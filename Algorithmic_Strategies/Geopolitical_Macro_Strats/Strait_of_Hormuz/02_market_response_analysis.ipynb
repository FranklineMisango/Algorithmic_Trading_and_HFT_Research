  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Correlation Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate correlations with shipping disruption and sentiment\n",
    "correlations = {}\n",
    "for asset in market_df.columns:\n",
    "    return_col = f'{asset}_Return'\n",
    "    \n",
    "    # Correlation with shipping disruption\n",
    "    ship_corr = analysis_df[[return_col, 'Disruption_Pct']].corr().iloc[0, 1]\n",
    "    \n",
    "    # Correlation with sentiment\n",
    "    sent_corr = analysis_df[[return_col, 'sentiment_mean']].corr().iloc[0, 1]\n",
    "    \n",
    "    correlations[asset] = {\n",
    "        'Shipping_Disruption': ship_corr,\n",
    "        'Sentiment': sent_corr\n",
    "    }\n",
    "\n",
    "corr_df = pd.DataFrame(correlations).T\n",
    "\n",
    "print(\"\\nMost NEGATIVELY correlated with Shipping Disruption (hurt by crisis):\")\n",
    "print(corr_df.nsmallest(10, 'Shipping_Disruption')['Shipping_Disruption'].round(3))\n",
    "\n",
    "print(\"\\nMost POSITIVELY correlated with Shipping Disruption (benefit from crisis):\")\n",
    "print(corr_df.nlargest(10, 'Shipping_Disruption')['Shipping_Disruption'].round(3))\n",
    "\n",
    "print(\"\\nMost NEGATIVELY correlated with Sentiment (hurt by negative sentiment):\")\n",
    "print(corr_df.nsmallest(10, 'Sentiment')['Sentiment'].round(3))\n",
    "\n",
    "print(\"\\nMost POSITIVELY correlated with Sentiment (benefit from negative sentiment):\")\n",
    "print(corr_df.nlargest(10, 'Sentiment')['Sentiment'].round(3))"
   ]
  }
,
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize correlation heatmap for asset classes\n",
    "class_corr = {}\n",
    "for class_name, assets in asset_classes.items():\n",
    "    if not assets:\n",
    "        continue\n",
    "    return_cols = [f'{a}_Return' for a in assets]\n",
    "    class_return = analysis_df[return_cols].mean(axis=1)\n",
    "    \n",
    "    ship_corr = pd.concat([class_return, analysis_df['Disruption_Pct']], axis=1).corr().iloc[0, 1]\n",
    "    sent_corr = pd.concat([class_return, analysis_df['sentiment_mean']], axis=1).corr().iloc[0, 1]\n",
    "    \n",
    "    class_corr[class_name] = {\n",
    "        'Shipping Disruption': ship_corr,\n",
    "        'Sentiment': sent_corr\n",
    "    }\n",
    "\n",
    "class_corr_df = pd.DataFrame(class_corr).T\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "sns.heatmap(class_corr_df, annot=True, fmt='.3f', cmap='RdYlGn', center=0, \n",
    "            cbar_kws={'label': 'Correlation'}, ax=ax, vmin=-0.5, vmax=0.5)\n",
    "ax.set_title('Asset Class Correlations with Disruption & Sentiment', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nAsset Class Correlations:\")\n",
    "print(class_corr_df.round(3))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Crisis Event Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Identify major crisis periods from sentiment data\n",
    "crisis_events = sentiment_df.groupby('crisis_event').agg({\n",
    "    'crisis_start': 'first',\n",
    "    'crisis_end': 'first',\n",
    "    'sentiment': 'mean',\n",
    "    'date': 'count',\n",
    "    'expected_severity': 'first'\n",
    "}).rename(columns={'date': 'article_count'})\n",
    "\n",
    "print(\"\\nIdentified Crisis Events:\")\n",
    "print(crisis_events)\n",
    "\n",
    "# Analyze each crisis event\n",
    "for event_name, event_data in crisis_events.iterrows():\n",
    "    start = pd.to_datetime(event_data['crisis_start'])\n",
    "    end = pd.to_datetime(event_data['crisis_end'])\n",
    "    \n",
    "    event_mask = (analysis_df.index >= start) & (analysis_df.index <= end)\n",
    "    event_df = analysis_df[event_mask]\n",
    "    \n",
    "    if len(event_df) == 0:\n",
    "        continue\n",
    "    \n",
    "    print(f\"\\n{'='*80}\")\n",
    "    print(f\"EVENT: {event_name}\")\n",
    "    print(f\"Period: {start.date()} to {end.date()} ({len(event_df)} trading days)\")\n",
    "    print(f\"Severity: {event_data['expected_severity']}\")\n",
    "    print(f\"{'='*80}\")\n",
    "    \n",
    "    # Calculate cumulative returns by asset class\n",
    "    print(\"\\nAsset Class Performance:\")\n",
    "    for class_name, assets in asset_classes.items():\n",
    "        if not assets:\n",
    "            continue\n",
    "        return_cols = [f'{a}_Return' for a in assets]\n",
    "        class_return = event_df[return_cols].mean(axis=1)\n",
    "        cum_return = (1 + class_return).prod() - 1\n",
    "        print(f\"  {class_name}: {cum_return * 100:+.2f}%\")\n",
    "    \n",
    "    # Shipping disruption\n",
    "    avg_disruption = event_df['Disruption_Pct'].mean()\n",
    "    print(f\"\\nAverage Shipping Disruption: {avg_disruption:.2f}%\")\n",
    "    print(f\"Average Sentiment: {event_df['sentiment_mean'].mean():.3f}\")\n",
    "    \n",
    "    # Top 5 winners and losers\n",
    "    event_returns = {}\n",
    "    for asset in market_df.columns:\n",
    "        return_col = f'{asset}_Return'\n",
    "        if return_col in event_df.columns:\n",
    "            cum_ret = (1 + event_df[return_col]).prod() - 1\n",
    "            event_returns[asset] = cum_ret * 100\n",
    "    \n",
    "    event_returns_series = pd.Series(event_returns).sort_values(ascending=False)\n",
    "    print(\"\\nTop 5 Winners:\")\n",
    "    print(event_returns_series.head(5).round(2))\n",
    "    print(\"\\nTop 5 Losers:\")\n",
    "    print(event_returns_series.tail(5).round(2))"
   ]
