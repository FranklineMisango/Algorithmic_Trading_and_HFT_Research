   "source": [
    "# Comprehensive Market Response Analysis\n",
    "## Ship Movement + AI Sentiment Impact Across All Asset Classes\n",
    "\n",
    "This notebook provides a unified view of how all markets respond to:\n",
    "- Strait of Hormuz shipping disruptions\n",
    "- AI-analyzed geopolitical sentiment from news\n",
    "- Combined impact of both factors\n",
    "\n",
    "### Asset Classes Covered:\n",
    "- Commodities (Oil, Gas, Shipping)\n",
    "- Equities (US, Europe, Asia)\n",
    "- Fixed Income (Treasuries, Corporate, EM)\n",
    "- Forex (Oil Exporters vs Importers)\n",
    "- Futures (ES, NQ, CL, BZ, NG)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from datetime import datetime, timedelta\n",
    "import warnings\n",
    "import glob\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette('husl')\n",
    "%matplotlib inline\n",
    "\n",
    "plt.rcParams['figure.figsize'] = (20, 12)\n",
    "plt.rcParams['font.size'] = 11"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load All Data Sources"
   ]
  }
 ],
 "nbformat": 4,
 "nbformat_minor": 4
}
,
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load shipping data\n",
    "print(\"Loading shipping data...\")\n",
    "shipping_df = pd.read_csv('Data/Portwatch_Shipment_Data/arrivals-of-ships.csv')\n",
    "shipping_df['DateTime'] = pd.to_datetime(shipping_df['DateTime'])\n",
    "shipping_df.set_index('DateTime', inplace=True)\n",
    "shipping_df['Total'] = shipping_df[['Container', 'Dry Bulk', 'General Cargo', 'Roll-on/roll-off', 'Tanker']].sum(axis=1)\n",
    "shipping_df['MA_30'] = shipping_df['Total'].rolling(30).mean()\n",
    "shipping_df['Disruption_Pct'] = ((shipping_df['Total'] - shipping_df['MA_30']) / shipping_df['MA_30']) * 100\n",
    "\n",
    "# Load sentiment data\n",
    "print(\"Loading sentiment data...\")\n",
    "sentiment_df = pd.read_csv('Data/crisis_sentiment_analysis.csv')\n",
    "sentiment_df['date'] = pd.to_datetime(sentiment_df['date'])\n",
    "\n",
    "sentiment_daily = pd.read_csv('Data/crisis_sentiment_daily.csv')\n",
    "sentiment_daily['date'] = pd.to_datetime(sentiment_daily['date'])\n",
    "sentiment_daily_indexed = sentiment_daily.set_index('date')\n",
    "\n",
    "print(f\"  Shipping: {len(shipping_df)} days\")\n",
    "print(f\"  Sentiment: {len(sentiment_df)} articles, {len(sentiment_daily)} daily records\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load all market data\n",
    "all_data = {}\n",
    "\n",
    "# Commodities\n",
    "print(\"\\nLoading commodities...\")\n",
    "for ticker in ['USO', 'BNO', 'UNG', 'BDRY']:\n",
    "    df = pd.read_parquet(f'Data/Commodities/{ticker}.parquet')\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'COMM_{ticker}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('COMM_')])} commodities\")\n",
    "\n",
    "# Futures\n",
    "print(\"Loading futures...\")\n",
    "for ticker in ['CL', 'BZ', 'NG', 'ES', 'NQ']:\n",
    "    df = pd.read_parquet(f'Data/Futures/{ticker}.parquet')\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'FUT_{ticker}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('FUT_')])} futures\")\n",
    "\n",
    "# Equities - US\n",
    "print(\"Loading US equities...\")\n",
    "us_files = glob.glob('Data/Equities/US/*.parquet')\n",
    "for file in us_files:\n",
    "    ticker = file.split('/')[-1].replace('.parquet', '')\n",
    "    df = pd.read_parquet(file)\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'US_{ticker}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('US_')])} US equities\")"
   ]
  }
 ],
