   "source": [
    "# Equities - Europe\n",
    "print(\"Loading Europe equities...\")\n",
    "eu_files = glob.glob('Data/Equities/Europe/*.parquet')\n",
    "for file in eu_files:\n",
    "    ticker = file.split('/')[-1].replace('.parquet', '')\n",
    "    df = pd.read_parquet(file)\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'EU_{ticker}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('EU_')])} Europe equities\")\n",
    "\n",
    "# Equities - Asia\n",
    "print(\"Loading Asia equities...\")\n",
    "asia_files = glob.glob('Data/Equities/Asia/*.parquet')\n",
    "for file in asia_files:\n",
    "    ticker = file.split('/')[-1].replace('.parquet', '')\n",
    "    df = pd.read_parquet(file)\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'ASIA_{ticker}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('ASIA_')])} Asia equities\")\n",
    "\n",
    "# Fixed Income\n",
    "print(\"Loading fixed income...\")\n",
    "fi_files = glob.glob('Data/Fixed_Income/*.parquet')\n",
    "for file in fi_files:\n",
    "    ticker = file.split('/')[-1].replace('.parquet', '')\n",
    "    df = pd.read_parquet(file)\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'FI_{ticker}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('FI_')])} fixed income\")\n",
    "\n",
    "# Forex\n",
    "print(\"Loading forex...\")\n",
    "fx_files = glob.glob('Data/Forex/*.parquet')\n",
    "for file in fx_files:\n",
    "    pair = file.split('/')[-1].replace('.parquet', '')\n",
    "    df = pd.read_parquet(file)\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    all_data[f'FX_{pair}'] = df['Close']\n",
    "print(f\"  Loaded {len([k for k in all_data.keys() if k.startswith('FX_')])} forex pairs\")\n",
    "\n",
    "# Combine all data\n",
    "market_df = pd.DataFrame(all_data)\n",
    "print(f\"\\nTotal assets loaded: {len(market_df.columns)}\")\n",
    "print(f\"Date range: {market_df.index.min()} to {market_df.index.max()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Prepare Analysis Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge market data with shipping and sentiment\n",
    "analysis_df = market_df.copy()\n",
    "analysis_df = analysis_df.join(shipping_df[['Total', 'Tanker', 'Disruption_Pct']], how='left')\n",
    "analysis_df = analysis_df.join(sentiment_daily_indexed[['sentiment_mean', 'article_count', 'risk_level']], how='left')\n",
    "\n",
    "# Forward fill shipping data\n",
    "analysis_df['Disruption_Pct'] = analysis_df['Disruption_Pct'].fillna(method='ffill')\n",
    "analysis_df['sentiment_mean'] = analysis_df['sentiment_mean'].fillna(0)\n",
    "analysis_df['article_count'] = analysis_df['article_count'].fillna(0)\n",
    "\n",
    "# Calculate returns for all assets\n",
    "for col in market_df.columns:\n",
    "    analysis_df[f'{col}_Return'] = analysis_df[col].pct_change()\n",
    "\n",
    "# Create crisis indicators\n",
    "analysis_df['Shipping_Crisis'] = (analysis_df['Disruption_Pct'] < -20).astype(int)\n",
    "analysis_df['Sentiment_Crisis'] = (analysis_df['sentiment_mean'] < -0.5).astype(int)\n",
    "analysis_df['Combined_Crisis'] = ((analysis_df['Shipping_Crisis'] == 1) | \n",
    "                                   (analysis_df['Sentiment_Crisis'] == 1)).astype(int)\n",
    "\n",
    "print(f\"Analysis DataFrame: {analysis_df.shape}\")\n",
    "print(f\"\\nCrisis Days:\")\n",
    "print(f\"  Shipping Crisis: {analysis_df['Shipping_Crisis'].sum()} days\")\n",
    "print(f\"  Sentiment Crisis: {analysis_df['Sentiment_Crisis'].sum()} days\")\n",
    "print(f\"  Combined Crisis: {analysis_df['Combined_Crisis'].sum()} days\")\n",
    "print(f\"  Normal: {(analysis_df['Combined_Crisis'] == 0).sum()} days\")"
   ]
  }
,
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Asset Class Performance Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define asset class groupings\n",
    "asset_classes = {\n",
    "    'Commodities': [c for c in market_df.columns if c.startswith('COMM_')],\n",
    "    'Futures': [c for c in market_df.columns if c.startswith('FUT_')],\n",
    "    'US Equities': [c for c in market_df.columns if c.startswith('US_')],\n",
    "    'Europe Equities': [c for c in market_df.columns if c.startswith('EU_')],\n",
    "    'Asia Equities': [c for c in market_df.columns if c.startswith('ASIA_')],\n",
    "    'Fixed Income': [c for c in market_df.columns if c.startswith('FI_')],\n",
    "    'Forex': [c for c in market_df.columns if c.startswith('FX_')]\n",
    "}\n",
    "\n",
    "# Define scenarios\n",
    "scenarios = {\n",
    "    'Normal': (analysis_df['Combined_Crisis'] == 0),\n",
    "    'Shipping Crisis': (analysis_df['Shipping_Crisis'] == 1),\n",
    "    'Sentiment Crisis': (analysis_df['Sentiment_Crisis'] == 1),\n",
    "    'Combined Crisis': ((analysis_df['Shipping_Crisis'] == 1) & (analysis_df['Sentiment_Crisis'] == 1))\n",
    "}\n",
    "\n",
    "# Calculate performance by asset class and scenario\n",
    "class_results = {}\n",
    "for class_name, assets in asset_classes.items():\n",
    "    if not assets:\n",
    "        continue\n",
    "    \n",
    "    return_cols = [f'{a}_Return' for a in assets]\n",
    "    class_return = analysis_df[return_cols].mean(axis=1)\n",
    "    \n",
    "    class_results[class_name] = {}\n",
    "    for scenario_name, mask in scenarios.items():\n",
    "        scenario_data = class_return[mask]\n",
    "        class_results[class_name][scenario_name] = scenario_data.mean() * 252 * 100\n",
    "        class_results[class_name][f'{scenario_name}_Vol'] = scenario_data.std() * np.sqrt(252) * 100\n",
    "        class_results[class_name][f'{scenario_name}_Days'] = mask.sum()\n",
    "\n",
    "class_results_df = pd.DataFrame(class_results).T\n",
    "return_cols = [c for c in class_results_df.columns if '_Vol' not in c and '_Days' not in c]\n",
    "\n",
    "print(\"\\nAsset Class Performance by Scenario (Annualized %):\")\n",
    "print(class_results_df[return_cols].round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize asset class performance\n",
    "fig, axes = plt.subplots(2, 2, figsize=(20, 14))\n",
    "\n",
    "# Plot 1: Returns by asset class\n",
    "class_results_df[return_cols].T.plot(kind='bar', ax=axes[0, 0], width=0.8)\n",
    "axes[0, 0].set_title('Asset Class Returns by Scenario', fontsize=16, fontweight='bold')\n",
    "axes[0, 0].set_ylabel('Annualized Return (%)')\n",
    "axes[0, 0].axhline(y=0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[0, 0].legend(title='Asset Class', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "axes[0, 0].grid(True, alpha=0.3)\n",
    "axes[0, 0].set_xticklabels(axes[0, 0].get_xticklabels(), rotation=45, ha='right')\n",
    "\n",
    "# Plot 2: Crisis impact (difference from normal)\n",
    "impact_df = class_results_df[return_cols].subtract(class_results_df['Normal'], axis=0).drop('Normal', axis=1)\n",
    "impact_df.T.plot(kind='bar', ax=axes[0, 1], width=0.8)\n",
    "axes[0, 1].set_title('Crisis Impact on Asset Classes (vs Normal)', fontsize=16, fontweight='bold')\n",
    "axes[0, 1].set_ylabel('Return Difference (%)')\n",
    "axes[0, 1].axhline(y=0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[0, 1].legend(title='Asset Class', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "axes[0, 1].grid(True, alpha=0.3)\n",
    "axes[0, 1].set_xticklabels(axes[0, 1].get_xticklabels(), rotation=45, ha='right')\n",
    "\n",
    "# Plot 3: Volatility comparison\n",
    "vol_cols = ['Normal_Vol', 'Combined Crisis_Vol']\n",
    "class_results_df[vol_cols].plot(kind='bar', ax=axes[1, 0], width=0.8)\n",
    "axes[1, 0].set_title('Volatility: Normal vs Combined Crisis', fontsize=16, fontweight='bold')\n",
    "axes[1, 0].set_ylabel('Annualized Volatility (%)')\n",
    "axes[1, 0].legend(['Normal', 'Combined Crisis'])\n",
    "axes[1, 0].grid(True, alpha=0.3)\n",
    "axes[1, 0].set_xticklabels(axes[1, 0].get_xticklabels(), rotation=45, ha='right')\n",
    "\n",
    "# Plot 4: Sharpe ratios\n",
    "sharpe_df = pd.DataFrame()\n",
    "for scenario in ['Normal', 'Combined Crisis']:\n",
    "    sharpe_df[scenario] = class_results_df[scenario] / class_results_df[f'{scenario}_Vol']\n",
    "\n",
    "sharpe_df.plot(kind='bar', ax=axes[1, 1], width=0.8)\n",
    "axes[1, 1].set_title('Sharpe Ratios by Asset Class', fontsize=16, fontweight='bold')\n",
    "axes[1, 1].set_ylabel('Sharpe Ratio')\n",
    "axes[1, 1].axhline(y=0, color='black', linestyle='-', linewidth=0.5)\n",
    "axes[1, 1].legend(['Normal', 'Combined Crisis'])\n",
    "axes[1, 1].grid(True, alpha=0.3)\n",
    "axes[1, 1].set_xticklabels(axes[1, 1].get_xticklabels(), rotation=45, ha='right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
,
  {
   "cell_type": "markdown",
