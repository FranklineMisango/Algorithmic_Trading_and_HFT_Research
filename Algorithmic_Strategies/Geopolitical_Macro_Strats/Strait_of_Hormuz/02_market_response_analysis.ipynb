   "source": [
    "# Calculate regional indices\n",
    "us_cols = [c for c in market_df.columns if c.startswith('US_')]\n",
    "eu_cols = [c for c in market_df.columns if c.startswith('EU_')]\n",
    "asia_cols = [c for c in market_df.columns if c.startswith('ASIA_')]\n",
    "\n",
    "analysis_df['US_Index'] = analysis_df[[f'{c}_Return' for c in us_cols]].mean(axis=1)\n",
    "analysis_df['EU_Index'] = analysis_df[[f'{c}_Return' for c in eu_cols]].mean(axis=1)\n",
    "analysis_df['ASIA_Index'] = analysis_df[[f'{c}_Return' for c in asia_cols]].mean(axis=1)\n",
    "\n",
    "regional_results = {}\n",
    "for region in ['US', 'EU', 'ASIA']:\n",
    "    regional_results[region] = {}\n",
    "    for scenario_name, mask in scenarios.items():\n",
    "        scenario_data = analysis_df[mask][f'{region}_Index']\n",
    "        regional_results[region][scenario_name] = scenario_data.mean() * 252 * 100\n",
    "        regional_results[region][f'{scenario_name}_Vol'] = scenario_data.std() * np.sqrt(252) * 100\n",
    "\n",
    "regional_df = pd.DataFrame(regional_results).T\n",
    "regional_return_cols = [c for c in regional_df.columns if '_Vol' not in c]\n",
    "\n",
    "print(\"\\nRegional Equity Performance (Annualized %):\")\n",
    "print(regional_df[regional_return_cols].round(2))\n",
    "\n",
